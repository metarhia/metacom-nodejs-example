{
  "name": "metacom-nodejs-example",
  "version": "1.0.0",
  "description": "Pure Node.js server with Metacom RPC protocol",
  "license": "MIT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "npm run -s lint",
    "lint": "eslint . && prettier -c \"**/*.js\" \"**/*.json\" \"**/*.md\"",
    "fix": "eslint . --fix && prettier --write \"**/*.js\" \"**/*.json\" \"**/*.md\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "metacom": "^3.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "eslint": "^10.0.2",
    "eslint-config-metarhia": "^9.1.8",
    "prettier": "^3.7.4"
  }
}
